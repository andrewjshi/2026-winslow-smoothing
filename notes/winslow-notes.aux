\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Comb pipeline with the dome reference. Top (\subref  {fig:combdome-clean}): clean comb input. Middle row: the raw Tutte embedding to the dome (\subref  {fig:combdome-tutte}) and the shape-optimized version with dome boundary pinned (\subref  {fig:combdome-opt}). Bottom row: direct (one-shot, no $\beta $-homotopy) Winslow back to the comb, started from the raw Tutte (\subref  {fig:combdome-winslow-tutte}) versus from the shape-optimized mesh (\subref  {fig:combdome-winslow-opt}). The raw-Tutte start produces the only output without inverted elements; the optimized-Tutte start produces a worse final mesh, indicating that the optimizer's local improvements on the dome reference are not aligned with the Winslow energy on the comb and degrade the physical pullback.\relax }}{25}{figure.caption.33}\protected@file@percent }
\newlabel{fig:combdome-pipeline}{{16}{25}{Comb pipeline with the dome reference. Top (\subref {fig:combdome-clean}): clean comb input. Middle row: the raw Tutte embedding to the dome (\subref {fig:combdome-tutte}) and the shape-optimized version with dome boundary pinned (\subref {fig:combdome-opt}). Bottom row: direct (one-shot, no $\beta $-homotopy) Winslow back to the comb, started from the raw Tutte (\subref {fig:combdome-winslow-tutte}) versus from the shape-optimized mesh (\subref {fig:combdome-winslow-opt}). The raw-Tutte start produces the only output without inverted elements; the optimized-Tutte start produces a worse final mesh, indicating that the optimizer's local improvements on the dome reference are not aligned with the Winslow energy on the comb and degrade the physical pullback.\relax }{figure.caption.33}{}}
