\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Configurations\nobreakspace  {}(A) and\nobreakspace  {}(B) on the L-shape with the unit-disk target. Row\nobreakspace  {}1: the proportional-arc Tutte disk (\subref  {fig:l-cmp-tutte}), shared input to both paths. Row\nobreakspace  {}2: shape optimization on the disk---(A) pins all boundary vertices at their Tutte positions (\subref  {fig:l-cmp-opt-pinned}); (B) pins only the six L-corners and lets the remaining boundary vertices slide tangentially along the unit circle (\subref  {fig:l-cmp-opt-slide}), so shape-opt redistributes boundary spacing and creates two clumps of small reference triangles next to L-corners. Row\nobreakspace  {}3: pinned Winslow on the physical L---(A) uses the original L-shape boundary as Dirichlet data (\subref  {fig:l-cmp-win-pinned}); (B) uses proportional-arc-pulled-back L-shape positions derived from the slid disk (\subref  {fig:l-cmp-win-slide}). Unlike the stadium (Figure\nobreakspace  {}\ref {fig:stadium-ab-pipeline}), the L-shape's corners give the disk-side clumping in (\subref  {fig:l-cmp-opt-slide}) somewhere to compress into on the physical side, producing a tight cluster of near-degenerate elements at the corresponding L-corners in (\subref  {fig:l-cmp-win-slide}).\relax }}{23}{figure.caption.28}\protected@file@percent }
\newlabel{fig:l-ab-pipeline}{{14}{23}{Configurations~(A) and~(B) on the L-shape with the unit-disk target. Row~1: the proportional-arc Tutte disk (\subref {fig:l-cmp-tutte}), shared input to both paths. Row~2: shape optimization on the disk---(A) pins all boundary vertices at their Tutte positions (\subref {fig:l-cmp-opt-pinned}); (B) pins only the six L-corners and lets the remaining boundary vertices slide tangentially along the unit circle (\subref {fig:l-cmp-opt-slide}), so shape-opt redistributes boundary spacing and creates two clumps of small reference triangles next to L-corners. Row~3: pinned Winslow on the physical L---(A) uses the original L-shape boundary as Dirichlet data (\subref {fig:l-cmp-win-pinned}); (B) uses proportional-arc-pulled-back L-shape positions derived from the slid disk (\subref {fig:l-cmp-win-slide}). Unlike the stadium (Figure~\ref {fig:stadium-ab-pipeline}), the L-shape's corners give the disk-side clumping in (\subref {fig:l-cmp-opt-slide}) somewhere to compress into on the physical side, producing a tight cluster of near-degenerate elements at the corresponding L-corners in (\subref {fig:l-cmp-win-slide}).\relax }{figure.caption.28}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Boundary correspondence between the comb (left) and the dome reference (right). Same color = same edge. The bottom and two short sides of the comb (gray) map to the same straight segments of the dome rectangle. Each tooth (blue, orange, yellow) maps to a contiguous arc of the dome cap; the gaps and margins (light gray) get the small angular allotments their physical arc lengths warrant. Mapping is isometric by arc length; the arc-length-matching constraint determines the cap height $b \approx 0.79$.\relax }}{24}{figure.caption.32}\protected@file@percent }
\newlabel{fig:combdome-preview}{{15}{24}{Boundary correspondence between the comb (left) and the dome reference (right). Same color = same edge. The bottom and two short sides of the comb (gray) map to the same straight segments of the dome rectangle. Each tooth (blue, orange, yellow) maps to a contiguous arc of the dome cap; the gaps and margins (light gray) get the small angular allotments their physical arc lengths warrant. Mapping is isometric by arc length; the arc-length-matching constraint determines the cap height $b \approx 0.79$.\relax }{figure.caption.32}{}}
