\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Configurations\nobreakspace  {}(A) and\nobreakspace  {}(B) on the convex stadium of Section\nobreakspace  {}\ref {sec:tutte-ex-stadium}. Row\nobreakspace  {}1: the proportional-arc Tutte disk (\subref  {fig:stadium-cmp-tutte}), shared input to both paths. Row\nobreakspace  {}2: shape optimization on the disk---(A) pins every boundary vertex (\subref  {fig:stadium-cmp-opt-pinned}); (B) pins eight evenly-spaced anchors and lets the remaining boundary vertices slide along the unit circle (\subref  {fig:stadium-cmp-opt-slide}). Rows\nobreakspace  {}3--4: pinned Winslow on the physical stadium---(A) uses the original stadium boundary as Dirichlet data (\subref  {fig:stadium-cmp-win-pinned}); (B) uses proportional-arc-pulled-back stadium positions derived from the slid disk (\subref  {fig:stadium-cmp-win-slide}). The slid-disk redistribution piles boundary density toward the curved end caps, but the smooth convex geometry has no corner for that density to compress into, so element shape in (B) stays good across the whole mesh.\relax }}{21}{figure.caption.26}\protected@file@percent }
\newlabel{fig:stadium-ab-pipeline}{{13}{21}{Configurations~(A) and~(B) on the convex stadium of Section~\ref {sec:tutte-ex-stadium}. Row~1: the proportional-arc Tutte disk (\subref {fig:stadium-cmp-tutte}), shared input to both paths. Row~2: shape optimization on the disk---(A) pins every boundary vertex (\subref {fig:stadium-cmp-opt-pinned}); (B) pins eight evenly-spaced anchors and lets the remaining boundary vertices slide along the unit circle (\subref {fig:stadium-cmp-opt-slide}). Rows~3--4: pinned Winslow on the physical stadium---(A) uses the original stadium boundary as Dirichlet data (\subref {fig:stadium-cmp-win-pinned}); (B) uses proportional-arc-pulled-back stadium positions derived from the slid disk (\subref {fig:stadium-cmp-win-slide}). The slid-disk redistribution piles boundary density toward the curved end caps, but the smooth convex geometry has no corner for that density to compress into, so element shape in (B) stays good across the whole mesh.\relax }{figure.caption.26}{}}
