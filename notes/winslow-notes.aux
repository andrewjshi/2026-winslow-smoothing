\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces L-shape pipeline with unit-square target. The six L-corners are marked in red; Tutte (\subref  {fig:l-sq-tutte}) places all six on the interior of straight square edges, because the boundary vertices it pins to the four square corners happen to be non-corner samples of the L. The Winslow step (\subref  {fig:l-sq-winslow}) produces a valid-looking L-shape mesh but with one slightly inverted element ($\min I = -0.019$, shown in red) near one of those six vertices that had to develop a sharp corner from a straight reference neighborhood.\relax }}{19}{figure.caption.21}\protected@file@percent }
\newlabel{fig:l-square-pipeline}{{11}{19}{L-shape pipeline with unit-square target. The six L-corners are marked in red; Tutte (\subref {fig:l-sq-tutte}) places all six on the interior of straight square edges, because the boundary vertices it pins to the four square corners happen to be non-corner samples of the L. The Winslow step (\subref {fig:l-sq-winslow}) produces a valid-looking L-shape mesh but with one slightly inverted element ($\min I = -0.019$, shown in red) near one of those six vertices that had to develop a sharp corner from a straight reference neighborhood.\relax }{figure.caption.21}{}}
