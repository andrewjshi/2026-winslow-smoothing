\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Zoom on the rightmost tooth. The pink region is the pendant block (tooth tip). Vertices $v_1, v_2$ (red circles, here labelled\nobreakspace  {}$17$ and\nobreakspace  {}$20$) are the only graph neighbours through which pendant vertices connect to the rest of the mesh. Removing them isolates the pink region: a $2$-vertex cut, i.e., graph connectivity $\le 2 < 3$.\relax }}{20}{figure.caption.28}\protected@file@percent }
\newlabel{fig:comb-cut}{{17}{20}{Zoom on the rightmost tooth. The pink region is the pendant block (tooth tip). Vertices $v_1, v_2$ (red circles, here labelled~$17$ and~$20$) are the only graph neighbours through which pendant vertices connect to the rest of the mesh. Removing them isolates the pink region: a $2$-vertex cut, i.e., graph connectivity $\le 2 < 3$.\relax }{figure.caption.28}{}}
